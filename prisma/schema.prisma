// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  username      String?
  location      String?
  language      String   @default("en")
  password      String?
  plan          String   @default("free")
  hearAbout     String?
  interests     String?  // comma-separated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  conversations Conversation[]
  savedResources SavedResource[]
  userSettings   UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  preview     String
  category    String?
  categoryColor String?
  confidence  Int      @default(0)
  isCrisis    Boolean  @default(false)
  isGuest     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("Conversation")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "ai" | "system"
  text           String
  category       String?
  confidence     Int?
  isCrisis       Boolean  @default(false)
  alternatives   String?  // JSON string
  resources      String?  // JSON string
  why            String?
  also           String?
  warning        String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("Message")
}

model SavedResource {
  id             String   @id @default(cuid())
  userId         String
  title          String
  category       String
  categoryColor  String   @default("#3b82f6")
  confidence     Int      @default(0)
  verifiedDate   String?
  action         String?
  detail         String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  language              String  @default("English")
  theme                 String  @default("light")
  zipCode               String?
  confidenceThreshold   Int     @default(70)
  defaultCategory       String  @default("All")
  autoClarification     Boolean @default(true)
  distanceUnit          String  @default("miles")
  notificationSound     Boolean @default(true)
  dataRetention         Boolean @default(true)
  shareUsage            Boolean @default(false)
  sessionTimeout        String  @default("30")
  ipMasking             Boolean @default(false)
  doNotTrack            Boolean @default(false)
  blockThirdPartyCookies Boolean @default(true)
  twoFactor             Boolean @default(false)
  emailNotifs           Boolean @default(true)
  resourceUpdates       Boolean @default(true)
  newFeatures           Boolean @default(false)
  weeklySummary         Boolean @default(false)
  largeText             Boolean @default(false)
  highContrast          Boolean @default(false)
  screenReader          Boolean @default(false)
  reducedMotion         Boolean @default(false)
  fontSize              String  @default("normal")
  density               String  @default("comfortable")
  sidebarPosition       String  @default("left")
  animationSpeed        String  @default("normal")
  autoDelete            String  @default("never")
  downloadFormat        String  @default("json")
  developerMode         Boolean @default(false)
  debugLogging          Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
