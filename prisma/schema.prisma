// ═══════════════════════════════════════════════════════════
// LORE — Knowledge Management Platform
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ─────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  username      String?  @unique
  passwordHash  String?
  plan          String   @default("free") // free, pro, enterprise
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  onboardingComplete Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  knowledgeNodes  KnowledgeNode[]
  knowledgeEdges  KnowledgeEdge[]
  notes           Note[]
  digests         Digest[]
  chatConversations ChatConversation[]
  userSettings    UserSettings?
  savedResources  SavedResource[]
  teamMemberships TeamMember[]
  blogPosts       BlogPost[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Knowledge Graph Models ─────────────────────────────

model KnowledgeNode {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String   @default("") @db.Text
  type        String   @default("concept") // concept, person, project, resource, idea
  color       String   @default("#4F46E5")
  icon        String?
  source      String?  // manual, ai, import, digest
  tags        String?  // comma-separated
  isFavorite  Boolean  @default(false)
  x           Float?   // position on graph
  y           Float?   // position on graph
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEdges KnowledgeEdge[]  @relation("SourceNodes")
  targetEdges KnowledgeEdge[]  @relation("TargetNodes")

  @@map("KnowledgeNode")
}

model KnowledgeEdge {
  id          String   @id @default(cuid())
  userId      String
  sourceId    String
  targetId    String
  label       String?  // relationship label
  type        String   @default("related") // related, depends_on, created_by, references, part_of
  strength    Int      @default(5) // 1-10
  createdAt   DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      KnowledgeNode  @relation("SourceNodes", fields: [sourceId], references: [id], onDelete: Cascade)
  target      KnowledgeNode  @relation("TargetNodes", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, label])
  @@map("KnowledgeEdge")
}

// ─── Morning Digest Models ──────────────────────────────

model Digest {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  summary     String   @db.Text
  keyInsights String   @db.Text // JSON array of strings
  connections String?  @db.Text // JSON array of connection objects
  mood        String?  // productive, neutral, slow
  focusAreas  String?  @db.Text // JSON array
  aiComment   String?  @db.Text // AI-generated personalized comment
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("Digest")
}

// ─── Structured Memory / Notes ──────────────────────────

model Note {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String   @default("") @db.Text
  type        String   @default("note") // note, bookmark, insight, snippet, meeting
  category    String?  // project name, topic, etc.
  tags        String?  // comma-separated
  pinned      Boolean  @default(false)
  aiSummary   String?  @db.Text // AI-generated summary
  sourceUrl   String?  // for bookmarks
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Note")
}

// ─── AI Chat Models ─────────────────────────────────────

model ChatConversation {
  id            String   @id @default(cuid())
  userId        String?
  title         String
  preview       String   @default("")
  pinned        Boolean  @default(false)
  category      String?
  categoryColor String?
  confidence    Float    @default(0)
  isCrisis      Boolean  @default(false)
  isGuest       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("ChatConversation")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "system"
  content        String   @db.Text
  category       String?
  confidence     Float?
  isCrisis       Boolean  @default(false)
  resources      String?  @db.Text // JSON array
  alternatives   String?  @db.Text // JSON array
  why            String?  @db.Text
  also           String?  @db.Text
  warning        String?  @db.Text
  metadata       String?  @db.Text // JSON: { sources, confidence, tokens }
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ChatMessage")
}

// ─── User Settings ──────────────────────────────────────

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  theme                 String  @default("light")
  language              String  @default("en")
  digestTime            String  @default("08:00")
  digestEnabled         Boolean @default(true)
  digestEmailNotif      Boolean @default(true)
  includeAIComment      Boolean @default(true)
  graphLayout           String  @default("force") // force, radial, tree
  graphShowLabels       Boolean @default(true)
  nodeSize              String  @default("medium") // small, medium, large
  edgeStyle             String  @default("solid") // solid, dashed
  animationSpeed        String  @default("normal") // slow, normal, fast
  chatModel             String  @default("default")
  chatStreamResponses   Boolean @default(true)
  showSources           Boolean @default(true)
  confidenceThreshold   Int     @default(70)
  memoryAutoTag         Boolean @default(true)
  memoryAutoLink        Boolean @default(true)
  sidebarPosition       String  @default("left")
  fontSize              String  @default("normal")
  reducedMotion         Boolean @default(false)
  emailNotifs           Boolean @default(true)
  weeklySummary         Boolean @default(true)
  newFeatures           Boolean @default(true)
  digestReminders       Boolean @default(true)
  twoFactor             Boolean @default(false)
  dataRetention         String  @default("90") // 30, 90, 365, forever
  developerMode         Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserSettings")
}

// ─── Team Models ────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      TeamMember[]
  invitations  TeamInvitation[]

  @@map("Team")
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  userId     String
  role       String   @default("viewer") // admin, editor, viewer
  joinedAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("TeamMember")
}

model TeamInvitation {
  id         String   @id @default(cuid())
  teamId     String
  email      String
  role       String   @default("viewer")
  message    String?  @db.Text
  token      String   @unique
  accepted   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("TeamInvitation")
}

// ─── Saved Resources ────────────────────────────────────

model SavedResource {
  id            String   @id @default(cuid())
  userId        String
  title         String
  category      String
  categoryColor String   @default("#3b82f6")
  confidence    Int      @default(0)
  verifiedDate  String?
  action        String?
  detail        String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("SavedResource")
}

// ─── Community Resources ────────────────────────────────

model CommunityResource {
  id            String   @id @default(cuid())
  name          String
  category      String
  description   String   @db.Text
  services      String?  @db.Text
  lastVerified  String?
  distance      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("CommunityResource")
}

// ─── Contact Submissions ─────────────────────────────────

model ContactSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  subject      String?
  urgency      String   @default("medium")
  message      String   @db.Text
  status       String   @default("new") // new, read, resolved
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ContactSubmission")
}

// ─── Resource (Community Resource Directory) ───────────

model Resource {
  id            String   @id @default(cuid())
  name          String
  category      String
  description   String   @db.Text
  services      String   @default("[]") @db.Text // JSON array
  languages     String   @default("[]") @db.Text // JSON array
  phone         String?
  address       String?
  hours         String?
  eligibility   String?
  url           String?
  zip           String?
  lastVerified  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("Resource")
}

// ─── Blog Posts ────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?   @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  tags        String    @default("[]") @db.Text // JSON array
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("BlogPost")
}

// ─── Newsletter Subscriptions ──────────────────────────

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("NewsletterSubscription")
}
