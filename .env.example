# ═══════════════════════════════════════════════════════
# ClearPath AI — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# ─── DATABASE ─────────────────────────────────────────
# Local development: SQLite
DATABASE_URL="file:../db/custom.db"

# Vercel deployment: Use Turso (libSQL) for persistent SQLite
# 1. Install Turso CLI: curl -sSfL https://get.turso.dev | bash
# 2. Create database: turso db create clearpath-ai
# 3. Get URL: turso db show clearpath-ai --url
# 4. Get auth token: turso db tokens create clearpath-ai
# DATABASE_URL="libsql://clearpath-ai-xxxx.aws-eu-west-1.turso.io?authToken=xxxx"

# ─── AUTHENTICATION ───────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE-ME-generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAUTH: GOOGLE ───────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3000/api/auth/callback/google
#    For Vercel: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="get-from-google-console"
GOOGLE_CLIENT_SECRET="get-from-google-console"

# ─── OAUTH: GITHUB ───────────────────────────────────
# 1. Go to https://github.com/settings/developers
# 2. New OAuth App
# 3. Authorization callback URL: http://localhost:3000/api/auth/callback/github
#    For Vercel: https://your-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID="get-from-github-settings"
GITHUB_CLIENT_SECRET="get-from-github-settings"

# ─── AI: HUGGING FACE ────────────────────────────────
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a token with "Read" access
# Without this key, the classify API falls back to keyword-based simulation
HUGGINGFACE_API_KEY="hf_xxxxx"
