# ═══════════════════════════════════════════════════════
# LORE — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# ─── DATABASE ─────────────────────────────────────────
# For Vercel deployment:
#   1. Create a Vercel Postgres database in your Vercel project dashboard
#   2. It will automatically set POSTGRES_URL and related env vars
#   3. Set DATABASE_URL to the same value as POSTGRES_URL
#
# For local development with PostgreSQL:
#   Install PostgreSQL locally and create a database called "lore"
#   DATABASE_URL="postgresql://user:password@localhost:5432/lore"
#
# For Vercel:
DATABASE_URL="postgresql://user:password@host:5432/lore"

# ─── AUTHENTICATION ───────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE-ME-generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# For Vercel: Set NEXTAUTH_URL to your production URL
# NEXTAUTH_URL="https://your-app.vercel.app"

# ─── OAUTH: GOOGLE (optional) ────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:3000/api/auth/callback/google
#    For Vercel: https://your-app.vercel.app/api/auth/callback/google
# GOOGLE_CLIENT_ID="get-from-google-console"
# GOOGLE_CLIENT_SECRET="get-from-google-console"

# ─── AI: HUGGING FACE (optional) ────────────────────
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a token with "Read" access
# Without this key, the classify API falls back to keyword-based simulation
# HUGGINGFACE_API_KEY="hf_xxxxx"

# ─── STRIPE (optional) ──────────────────────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
